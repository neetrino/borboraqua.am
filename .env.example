# Единственный файл с секретами — в корне. Для Next.js и Prisma создайте симлинки:
#   apps/web/.env     → ../../.env
#   packages/db/.env  → ../../.env
# (ln -s ../../.env .env из папки apps/web или packages/db)

# -----------------------------------------------------------------------------
# Database (Neon / local PostgreSQL)
# P0: pooled host (-pooler), sslmode=require. connection_limit / pool_timeout — в коде или ниже.
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://user:@host:5432/dbname?schema=public"
# Опционально (Prisma serverless / P2024). Если не задано — в packages/db/client.ts подставятся дефолты.
DATABASE_CONNECTION_LIMIT="10"
DATABASE_POOL_TIMEOUT="20"

# -----------------------------------------------------------------------------
# Vercel (Production / Preview) — скопируй в Project → Settings → Environment Variables
# Минимум для деплоя: все переменные из этого файла, которые используются в коде.
# НОВЫЕ для снижения P2024 (если ещё не добавлял): DATABASE_POOL_TIMEOUT, при желании DATABASE_CONNECTION_LIMIT.
# APP_URL / NEXT_PUBLIC_API_URL для prod: https://borboraqua.am
# -----------------------------------------------------------------------------

# Authentication
JWT_SECRET=""
JWT_EXPIRES_IN="7d"

# Search (Meilisearch, optional)
#MEILISEARCH_HOST="http://localhost:7700"
#MEILISEARCH_API_KEY=""

# Cloudflare R2 (product image uploads)
R2_ENDPOINT="https://<account_id>.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="borboraqua"
R2_PUBLIC_URL="https://pub-xxxx.r2.dev"

# Application
NODE_ENV="development"
# APP_URL: canonical site URL (redirects, payment callbacks). Also used as allowed origin for API/CSRF; for tunnel use e.g. https://dev.neetrino.com
# For FastShift live testing via tunnel: set APP_URL="https://borboraqua.am" so callback_url uses prod domain (see docs/payments/FASTSHIFT-INTEGRATION.md)
APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL=""


# Upstash Redis (cache, rate limiting, etc.)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Payments — test/live credentials from Ameriabank, Idram, Telcell, FastShift (see docs/06-PAYMENT-INTEGRATION-PLAN.md)
AMERIA_TEST_MODE="true"
AMERIA_CLIENT_ID=""
AMERIA_USERNAME=""
AMERIA_PASSWORD=""
AMERIA_LIVE_CLIENT_ID=""
AMERIA_LIVE_USERNAME=""
AMERIA_LIVE_PASSWORD=""
IDRAM_TEST_MODE="true"
IDRAM_REC_ACCOUNT=""
IDRAM_SECRET_KEY=""
IDRAM_LIVE_REC_ACCOUNT=""
IDRAM_LIVE_SECRET_KEY=""
TELCELL_TEST_MODE="true"
TELCELL_SHOP_ID=""
TELCELL_SHOP_KEY=""
TELCELL_LIVE_SHOP_ID=""
TELCELL_LIVE_SHOP_KEY=""
FASTSHIFT_TEST_MODE="true"
FASTSHIFT_TOKEN=""
FASTSHIFT_LIVE_TOKEN=""

# EHDM (Էլեկտրոնային ՀԴՄ — fiscal receipts, see docs/payments/EHDM-INTEGRATION.md)
# .crt/.key files: store OUTSIDE repo (e.g. Private/ locally, path in env). Never commit cert/key or passphrase.
EHDM_API_URL="https://ecrm.taxservice.am/taxsystem-rs-vcr/api/v1.0"
EHDM_CRN=""
EHDM_TIN=""
# Сертификат/ключ: на Vercel удобнее base64 (см. apps/web/lib/payments/ehdm/config.ts)
EHDM_CERT_BASE64=""
EHDM_KEY_BASE64=""
EHDM_CERT_PATH=""
EHDM_KEY_PATH=""
EHDM_KEY_PASSPHRASE=""
# 200+ при переходе со старого сайта (чтобы не пересечься с seq старого сайта)
EHDM_INITIAL_SEQ="200"
EHDM_DEFAULT_ADG_CODE="2201"
EHDM_DEP="1" # 1=16.67% ԱԱՀ-ով հարկվող, 2=0% ԱԱՀ-ով չհարկվող, 3= Շրջ. հարկ, 7= Միկրոձեռնարկատիրություն
EHDM_DEFAULT_UNIT="Հատ"
EHDM_CASHIER_ID="1"
EHDM_SHIPPING_ENABLED="1"
EHDM_SHIPPING_ADG_CODE="49.42"
EHDM_SHIPPING_GOOD_CODE="007"
EHDM_SHIPPING_DESCRIPTION="Առաքում"
EHDM_SHIPPING_UNIT="Հատ"
